<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My GitHub Page</title>

  <style>
    body{
      font-family: Arial, sans-serif;
      text-align:center;
      background:#f5f5f5;
    }

    .container{
      margin-top:100px;
    }

    button{
      padding:10px 20px;
      border:none;
      background:#2c7be5;
      color:white;
      border-radius:6px;
      cursor:pointer;
    }

    button:hover{
      background:#1a5fd0;
    }
  </style>
</head>

<body>

<div class="container">
  <h1>Welcome to My GitHub Page 🚀</h1>
  <p>This site is deployed using GitHub Pages.</p>

  <button onclick="showMessage()">Click Me</button>
</div>

<script>
function showMessage(){
  alert("Hello from GitHub Pages!");
}
</script>

</body>
</html>
